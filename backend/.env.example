# --- LLM (SovereignEG, OpenAI-compatible) ---
# Get a key at https://sovereigneg.com/ -> Get API Key
LLM_BASE_URL=https://sovereigneg.com/v1
LLM_API_KEY=sk-your-sovereigneg-key
# Pick any model id from the SovereignEG catalog dashboard.
LLM_MODEL=gpt-4o-mini

# --- Local fallback (optional) ---
# If LLM_API_KEY is empty, the backend falls back to local Ollama when reachable.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# --- SearXNG (retrieval fallback) ---
SEARXNG_URL=http://localhost:8080

# --- Security / governance ---
# Require X-API-Key on protected endpoints. Default off so the demo/frontend works.
REQUIRE_AUTH=0
# Comma-separated CORS origins. Ignored ("*") only when REQUIRE_AUTH=0.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
# Per-minute request cap per identity (0 disables).
RATE_LIMIT_PER_MIN=60
# Stable secret so audit-log HMAC signatures survive restarts (set in production).
AUDIT_HMAC_SECRET=

# --- Persistence (SQLite) ---
AUDIT_DB_PATH=audit.db
APP_DB_PATH=app.db

# --- LLM cost telemetry (USD per 1K tokens; rough estimate) ---
PRICE_PER_1K_PROMPT=0.00015
PRICE_PER_1K_COMPLETION=0.0006
